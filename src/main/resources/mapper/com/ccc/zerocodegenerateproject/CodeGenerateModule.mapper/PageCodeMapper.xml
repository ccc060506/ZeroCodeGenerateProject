<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ccc.zerocodegenerateproject.codeGenerateModule.mapper.PageCodeMapper">
    <select id="getVersionList">
        select *
        from PageVersion
        where pageDSLId = #{pageId}
    </select>

    <delete id="deleteByVersion">
        delete from PageVersion
        where pageDSLId = #{pageId}
          and versionNum = #{version}
    </delete>

</mapper>
